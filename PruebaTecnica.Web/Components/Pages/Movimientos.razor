@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.QuickGrid
@inject ITipoMovimientoService Servicio

<PageTitle>Tipos de Movimiento</PageTitle>

<h1>Tipos de Movimiento</h1>
<p class="descripcion">
    Datos consumidos desde la API REST y desplegados con QuickGrid.
    Ordenamiento por columna y filtro de búsqueda incluidos.
</p>

@if (_cargando)
{
    <div class="estado estado-cargando" role="status">
        <div class="spinner"></div>
        <span>Cargando datos de la API…</span>
    </div>
}
else if (_error is not null)
{
    <div class="estado estado-error" role="alert">
        <p><strong>Ocurrió un problema:</strong> @_error</p>
        <button class="boton" @onclick="CargarAsync">Reintentar</button>
    </div>
}
else if (_movimientos is { Count: 0 })
{
    <div class="estado estado-vacio">
        <p>La API no retornó registros.</p>
        <button class="boton" @onclick="CargarAsync">Actualizar</button>
    </div>
}
else
{
    <div class="chips-resumen">
        <span class="chip">Total @_movimientos!.Count</span>
        <span class="chip chip-activa">Activas @_movimientos.Count(m => m.VActiva)</span>
        <span class="chip chip-inactiva">Inactivas @_movimientos.Count(m => !m.VActiva)</span>
    </div>

    <div class="barra-herramientas">
        <div class="campo-busqueda">
            <input class="filtro"
                   type="search"
                   placeholder="Filtrar por código o descripción…"
                   @bind="_filtro"
                   @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(_filtro))
            {
                <button class="limpiar-busqueda"
                        type="button"
                        title="Limpiar búsqueda"
                        @onclick="() => _filtro = string.Empty">×</button>
            }
        </div>
        <div class="segmentado" role="group" aria-label="Filtrar por estado">
            <button type="button" class="@ClaseSegmento(null)" @onclick="() => _filtroEstado = null">Todas</button>
            <button type="button" class="@ClaseSegmento(true)" @onclick="() => _filtroEstado = true">Activas</button>
            <button type="button" class="@ClaseSegmento(false)" @onclick="() => _filtroEstado = false">Inactivas</button>
        </div>
        <span class="conteo">@MovimientosFiltrados.Count() de @_movimientos.Count registros</span>
    </div>

    @if (!MovimientosFiltrados.Any())
    {
        <div class="estado estado-vacio">
            <p>No hay resultados para «@_filtro»</p>
            <button class="boton" @onclick="LimpiarFiltros">Limpiar filtros</button>
        </div>
    }
    else
    {
        <div class="tarjeta-grilla">
            <QuickGrid Items="MovimientosFiltrados" Class="grilla" Pagination="_paginacion">
                <PropertyColumn Property="@(m => m.Codigo)" Title="Código" Sortable="true" />
                <PropertyColumn Property="@(m => m.Descripcion)" Title="Descripción" Sortable="true" />
                <TemplateColumn Title="Estado" Sortable="true" SortBy="_ordenPorEstado">
                    <EstadoBadge Activa="context.VActiva" />
                </TemplateColumn>
            </QuickGrid>
            <Paginator State="_paginacion" />
        </div>
    }
}

@code {
    private IReadOnlyList<TipoMovimiento>? _movimientos;
    private string? _error;
    private bool _cargando = true;
    private string _filtro = string.Empty;
    private bool? _filtroEstado;

    private readonly PaginationState _paginacion = new() { ItemsPerPage = 8 };

    private readonly GridSort<TipoMovimiento> _ordenPorEstado =
        GridSort<TipoMovimiento>.ByAscending(m => m.VActiva);

    private IQueryable<TipoMovimiento> MovimientosFiltrados =>
        (_movimientos ?? Array.Empty<TipoMovimiento>())
            .Where(m => _filtroEstado is null || m.VActiva == _filtroEstado)
            .Where(m => string.IsNullOrWhiteSpace(_filtro)
                || m.Descripcion.Contains(_filtro, StringComparison.OrdinalIgnoreCase)
                || m.Codigo.ToString().Contains(_filtro))
            .AsQueryable();

    private string ClaseSegmento(bool? estado) =>
        _filtroEstado == estado ? "segmento segmento-activo" : "segmento";

    private void LimpiarFiltros()
    {
        _filtro = string.Empty;
        _filtroEstado = null;
    }

    protected override Task OnInitializedAsync() => CargarAsync();

    private async Task CargarAsync()
    {
        _cargando = true;
        _error = null;

        var resultado = await Servicio.ObtenerAsync();

        if (resultado.Exito)
        {
            _movimientos = resultado.Datos;
        }
        else
        {
            _error = resultado.Error;
        }

        _cargando = false;
    }
}
